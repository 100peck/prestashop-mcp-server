{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -e ."
  },
  "deploy": {
    "startCommand": "echo \"URL: $PRESTASHOP_SHOP_URL\" && python -m prestashop_mcp.prestashop_mcp_server",
    "restartPolicyType": "ON_FAILURE"
  }
}